<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <title>DroneVision AI | Aerial Insights</title>
</head>
<body>

    <nav class="navbar">
        <div class="logo">DRONEVISION AI</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="#about">About</a>
            <a href="/dataset">Dataset</a>
            <a href="/login">Login</a>
            <a href="/register" class="register-btn">Register</a>
        </div>
    </nav>

    <section class="hero-container">
        <div class="hero-content">
            <h1 class="hero-title">
                Advanced Aerial <br>
                <span class="text-gradient">Image Segmentation</span> <br>
                Using Drone Data
            </h1>
            <p class="hero-subtitle">
                A professional platform providing high-quality annotated drone imagery for 
                semantic segmentation, computer vision research, and AI development.
            </p>
            <div class="hero-buttons">
                <a href="/dataset" class="btn btn-primary">Explore Dataset</a>
                <a href="/register" class="btn btn-secondary">Get Started</a>
            </div>
        </div>

        <div class="hero-image-wrapper">
            <img src="{{ url_for('static', filename='drone-city.jpg') }}" 
                 alt="Aerial view of city with segmentation mask" 
                 class="hero-image">
            
            <div class="floating-badge">
                <span class="pulse"></span> AI Analysis Active
            </div>
        </div>
    </section>

</body>
</html>